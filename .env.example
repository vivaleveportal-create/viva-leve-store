# ─────────────────────────────────────────────
# App (Viva Leve Portal)
# ─────────────────────────────────────────────
NEXT_PUBLIC_STORE_URL=https://vivaleveportal.vercel.app
NEXT_PUBLIC_STORE_NAME="Viva Leve Portal"

# ─────────────────────────────────────────────
# MongoDB (Atlas Production)
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB_NAME=VivaLevePortal

# ─────────────────────────────────────────────
# Auth Admin (NextAuth v5)
# ─────────────────────────────────────────────
NEXTAUTH_SECRET=generate_a_strong_random_string_here
NEXTAUTH_URL=https://vivaleveportal.vercel.app

# ─────────────────────────────────────────────
# Auth Customer (Custom JWT)
# ─────────────────────────────────────────────
JWT_SECRET=another_strong_random_string_here

# ─────────────────────────────────────────────
# Cloudinary (Product & Avatar Images)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────────
# Logzz Integration (Physical Fulfillment)
# ─────────────────────────────────────────────
LOGZZ_API_KEY=your_logzz_api_key_here # Used in src/lib/services/logzz.ts

# ─────────────────────────────────────────────
# Stripe (Payments)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─────────────────────────────────────────────
# Email (Nodemailer SMTP / resend)
# ─────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=user@domain.com
EMAIL_SMTP_PASS=app_password_here
EMAIL_FROM="Viva Leve Portal <contato@vivaleveportal.com.br>"

# ─────────────────────────────────────────────
# Google OAuth (Customer Sign-in)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
